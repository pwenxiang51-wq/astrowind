---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: '文祥的赛博实验室 — Velox 极客基地',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  
  <Hero
    image={{ src: 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=1200', alt: 'Velox 极客主板' }}
  >
    <Fragment slot="title">
      文祥的赛博实验室：<br/>
      <span class="text-accent dark:text-white">Velox 极客基地</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">专注 VPS 高级运维、自动化脚本开发与独立站出海实战。</span><br/>
      摆脱 Shopify 的高昂月租，用纯静态无头架构打造秒开级的高级外贸独立站。一次性交付，终身无抽成。
    </Fragment>
  </Hero>

  <div class="mt-4 mb-32 flex justify-center">
    <button class="snipcart-add-item bg-blue-600 text-white px-10 py-4 rounded-full font-bold text-xl hover:bg-blue-700 shadow-2xl transition duration-300 transform hover:scale-105"
      data-item-id="velox-pro-build"
      data-item-price="2999.00"
      data-item-image="https://images.unsplash.com/photo-1518770660439-4636190af475?w=300"
      data-item-name="顶级极客独立站 (终身买断制)">
      🛒 立即购买独立站搭建服务 ($2999)
    </button>
  </div>

</Layout>
