---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'VELOX',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  
  <Hero
    image={{ src: 'https://images.unsplash.com/photo-1518770660439-4636190af475?w=1200', alt: 'Velox Core' }}
  >
    <Fragment slot="title">
      <span class="text-accent dark:text-white uppercase tracking-widest">VELOX</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold">Empowering your digital journey.</span><br/>
      Premium tools, scripts, and gear for creators and developers worldwide.
    </Fragment>
  </Hero>

  <div class="mt-8 max-w-6xl mx-auto px-4 sm:px-6 mb-24">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Featured Products</h2>
      <p class="mt-4 text-lg text-gray-500">Curated essentials for your workspace.</p>
    </div>

    <div class="grid grid-cols-1 gap-y-10 sm:grid-cols-2 gap-x-6 lg:grid-cols-3 xl:gap-x-8">
      
      <div class="group relative bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 p-4 hover:shadow-xl transition-shadow">
        <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden rounded-xl bg-gray-200 h-64">
          <img src="https://images.unsplash.com/photo-1595225476474-87563907a212?w=500" alt="VPS Script" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
        </div>
        <div class="mt-5 flex justify-between items-end">
          <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Auto Deploy Script</h3>
            <p class="mt-1 text-sm text-gray-500">Instant Server Setup</p>
          </div>
          <p class="text-xl font-black text-blue-600">$29.99</p>
        </div>
        <button class="snipcart-add-item mt-5 w-full bg-gray-900 dark:bg-white dark:text-gray-900 text-white py-3 px-4 rounded-xl font-bold hover:bg-blue-600 dark:hover:bg-blue-500 hover:text-white transition shadow-lg"
          data-item-id="prod-01" data-item-price="29.99" data-item-image="https://images.unsplash.com/photo-1595225476474-87563907a212?w=500" data-item-name="Auto Deploy Script">
          🛒 Add to Cart
        </button>
      </div>

      <div class="group relative bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 p-4 hover:shadow-xl transition-shadow">
        <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden rounded-xl bg-gray-200 h-64">
       <img src="https://images.unsplash.com/photo-1555680202-c86f0e12f086?w=500" alt="Keyboard" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">        </div>
        <div class="mt-5 flex justify-between items-end">
          <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Pro Keyboard</h3>
            <p class="mt-1 text-sm text-gray-500">Wireless Mechanical</p>
          </div>
          <p class="text-xl font-black text-blue-600">$149.00</p>
        </div>
        <button class="snipcart-add-item mt-5 w-full bg-gray-900 dark:bg-white dark:text-gray-900 text-white py-3 px-4 rounded-xl font-bold hover:bg-blue-600 dark:hover:bg-blue-500 hover:text-white transition shadow-lg"
          data-item-id="prod-02" data-item-price="149.00" data-item-image="https://images.unsplash.com/photo-1511467687858-23d9fae243ac?w=500" data-item-name="Pro Keyboard">
          🛒 Add to Cart
        </button>
      </div>

      <div class="group relative bg-white dark:bg-slate-800 rounded-2xl shadow-sm border border-gray-100 dark:border-slate-700 p-4 hover:shadow-xl transition-shadow">
        <div class="aspect-w-1 aspect-h-1 w-full overflow-hidden rounded-xl bg-gray-200 h-64">
          <img src="https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?w=500" alt="Workspace" class="h-full w-full object-cover object-center group-hover:scale-105 transition-transform duration-500">
        </div>
        <div class="mt-5 flex justify-between items-end">
          <div>
            <h3 class="text-lg font-bold text-gray-900 dark:text-white">Zero Trust Guide</h3>
            <p class="mt-1 text-sm text-gray-500">PDF E-Book</p>
          </div>
          <p class="text-xl font-black text-blue-600">$19.99</p>
        </div>
        <button class="snipcart-add-item mt-5 w-full bg-gray-900 dark:bg-white dark:text-gray-900 text-white py-3 px-4 rounded-xl font-bold hover:bg-blue-600 dark:hover:bg-blue-500 hover:text-white transition shadow-lg"
          data-item-id="prod-03" data-item-price="19.99" data-item-image="https://images.unsplash.com/photo-1499951360447-b19be8fe80f5?w=500" data-item-name="Zero Trust Guide">
          🛒 Add to Cart
        </button>
      </div>

    </div>
  </div>

</Layout>
